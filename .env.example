# ═══════════════════════════════════════════════════════════════════════════════
# RAG MCP Server — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and customize as needed.
# All values below are the defaults.

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PORT=18484

# ── Ingestion ────────────────────────────────────────────────────────────────
COLLECTION_NAME=rag_knowledge
CHUNK_SIZE=800
CHUNK_OVERLAP=120
FILE_EXTENSIONS=.md,.txt

# ── MCP Server ───────────────────────────────────────────────────────────────
MCP_PORT=18485
MCP_SERVER_NAME=RAG Knowledge Server
